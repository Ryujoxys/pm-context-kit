# Local repository mirror root.
CODE_CONTEXT_REPOS_ROOT=./repos

# Repository metadata config.
CODE_CONTEXT_CONFIG=./config/repos.yaml

# Optional visibility policy. Engineering can use this to hide sensitive repos/paths.
CODE_CONTEXT_VISIBILITY_CONFIG=./config/visibility.yaml

# Example HTTPS basic auth for a private repository.
ORDER_SERVICE_GIT_TOKEN=__CHANGE_ME__

# Only needed when using HTTPS basic auth.
ORDER_SERVICE_GIT_USERNAME=__CHANGE_ME__
